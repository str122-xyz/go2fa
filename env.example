# ============================================================
# .env.example — konfigurasi environment
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke repository!
# ============================================================

# Server
PORT=8080

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=useremoney
DB_PASSWORD=your-mysql-password
DB_NAME=emoney

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase
# Download dari: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=firebase_service_account.json

# SMTP Gmail
# Cara mendapatkan App Password:
# myaccount.google.com → Keamanan → Verifikasi 2 Langkah → Sandi Aplikasi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=E-Money App

# OTP
OTP_EXPIRY_MINUTES=5
